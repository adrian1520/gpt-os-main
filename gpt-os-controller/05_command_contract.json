{
  "version": "3.0",

  "config": {
    "strict_mode": true,
    "auto_debug": true,
    "max_steps": 12
  },

  "blocks": {
    "get_latest_run": [
      {
        "type": "api",
        "action": "listWorkflowRuns",
        "params": { "per_page": 1 }
      },
      {
        "type": "extract",
        "path": "workflow_runs[0].id",
        "as": "run_id"
      },
      {
        "type": "extract",
        "path": "workflow_runs[0].status",
        "as": "status"
      },
      {
        "type": "extract",
        "path": "workflow_runs[0].conclusion",
        "as": "conclusion"
      }
    ]
  },

  "commands": {

    "check_logs": {
      "intent": [
        "logi",
        "logs",
        "error",
        "błąd",
        "co się wywaliło",
        "status run",
        "co nie działa"
      ],

      "flow": [
        { "type": "use_block", "name": "get_latest_run" },

        {
          "type": "condition",
          "if": { "left": "run_id", "operator": "==", "right": null },
          "then": { "type": "return", "value": "⚠ BRAK DANYCH" }
        },

        {
          "type": "condition",
          "if": { "left": "status", "operator": "!=", "right": "completed" },
          "then": { "type": "return", "value": "⏳ still running" }
        },

        {
          "type": "condition",
          "if": { "left": "conclusion", "operator": "==", "right": "success" },
          "then": { "type": "return", "value": "✅ OK" }
        },

        {
          "type": "condition",
          "if": { "left": "conclusion", "operator": "==", "right": "failure" },
          "then": { "type": "return", "value": "DEBUG_REQUIRED" }
        },

        {
          "type": "api",
          "action": "listJobsForWorkflowRun",
          "params": {
            "run_id": "${run_id}"
          }
        },

        {
          "type": "condition",
          "if": {
            "left": "last_response.jobs",
            "operator": "==",
            "right": null
          },
          "then": {
            "type": "return",
            "value": "⚠ BRAK JOBS"
          }
        },

        {
          "type": "transform",
          "mode": "select_failed_job",
          "input": "last_response.jobs",
          "output": "failed_job"
        },

        {
          "type": "condition",
          "if": {
            "left": "failed_job",
            "operator": "==",
            "right": null
          },
          "then": {
            "type": "return",
            "value": "⚠ NO FAILED JOB"
          }
        },

        {
          "type": "extract",
          "path": "failed_job.steps",
          "as": "steps"
        }
      ],

      "on_error": {
        "type": "return",
        "value": "❌ jobs_fetch_failed"
      }
    },

    "debug_system": {
      "intent": [
        "debug",
        "napraw",
        "fix system",
        "dlaczego nie działa"
      ],

      "flow": [
        { "type": "use_block", "name": "get_latest_run" },

        {
          "type": "api",
          "action": "listJobsForWorkflowRun",
          "params": {
            "run_id": "${run_id}"
          }
        },

        {
          "type": "condition",
          "if": {
            "left": "last_response.jobs",
            "operator": "==",
            "right": null
          },
          "then": {
            "type": "return",
            "value": "⚠ BRAK JOBS"
          }
        },

        {
          "type": "transform",
          "mode": "select_failed_job",
          "input": "last_response.jobs",
          "output": "failed_job"
        },

        {
          "type": "condition",
          "if": {
            "left": "failed_job",
            "operator": "==",
            "right": null
          },
          "then": {
            "type": "return",
            "value": "⚠ NO FAILED JOB"
          }
        },

        {
          "type": "extract",
          "path": "failed_job.steps",
          "as": "steps"
        },

        {
          "type": "transform",
          "mode": "extract_logs_text",
          "input": "steps",
          "output": "logs"
        },

        {
          "type": "transform",
          "mode": "classify_error",
          "input": "logs",
          "output": "error_type"
        },

        {
          "type": "return",
          "value": "debug_analysis_complete"
        }
      ]
    },

    "read_file": {
      "intent": ["czytaj", "read file"],

      "flow": [
        {
          "type": "api",
          "action": "getFileContent",
          "params": {
            "path": "${path}"
          }
        }
      ],

      "on_error": {
        "type": "return",
        "value": "❌ file_not_found"
      }
    },

    "write_file": {
      "intent": ["zapisz plik", "write file"],

      "flow": [
        {
          "type": "api",
          "action": "getFileContent",
          "params": {
            "path": "${path}"
          }
        },
        {
          "type": "extract",
          "path": "sha",
          "as": "sha"
        },
        {
          "type": "condition",
          "if": {
            "left": "sha",
            "operator": "==",
            "right": null
          },
          "then": {
            "type": "api",
            "action": "createOrUpdateFile",
            "params": {
              "path": "${path}",
              "content": "${base64_content}",
              "message": "${message}"
            }
          }
        },
        {
          "type": "api",
          "action": "createOrUpdateFile",
          "params": {
            "path": "${path}",
            "sha": "${sha}",
            "content": "${base64_content}",
            "message": "${message}"
          }
        }
      ],

      "on_error": {
        "type": "return",
        "value": "❌ write_failed"
      }
    },

    "run_analysis": {
      "intent": ["analizuj", "run analysis"],

      "flow": [
        {
          "type": "api",
          "action": "repositoryDispatch",
          "params": {
            "event_type": "run_analysis"
          }
        }
      ]
    },

    "list_files": {
      "intent": ["pliki", "files", "repo tree"],

      "flow": [
        {
          "type": "api",
          "action": "getRepositoryTree"
        }
      ]
    }

  }
}