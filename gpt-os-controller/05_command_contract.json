{
  "version": "4.0",

  "config": {
    "strict_mode": true,
    "auto_debug": true,
    "max_steps": 15
  },

  "blocks": {

    "read_sot": [
      { "type": "api", "action": "getFileContent", "params": { "path": "memory/source_of_truth.json" } },
      { "type": "extract", "path": "content", "as": "sot_raw" }
    ],

    "get_latest_run": [
      { "type": "api", "action": "listWorkflowRuns", "params": { "per_page": 1 } },
      { "type": "extract", "path": "workflow_runs[0].id", "as": "run_id" },
      { "type": "extract", "path": "workflow_runs[0].conclusion", "as": "conclusion" }
    ]
  },

  "commands": {

    "read_file": {
      "intent": ["read file", "czytaj plik"],
      "flow": [
        { "type": "api", "action": "getFileContent", "params": { "path": "${path}" } }
      ]
    },

    "write_file": {
      "intent": ["write file", "zapisz plik"],
      "flow": [
        { "type": "api", "action": "getFileContent", "params": { "path": "${path}" } },
        { "type": "extract", "path": "sha", "as": "sha" },

        {
          "type": "interpreter",
          "input": "${content}",
          "output": "encoded_content"
        },

        {
          "type": "api",
          "action": "createOrUpdateFile",
          "params": {
            "path": "${path}",
            "sha": "${sha}",
            "content": "${encoded_content}",
            "message": "${message}"
          }
        }
      ]
    },

    "debug_system": {
      "intent": ["debug", "napraw", "fix system"],
      "flow": [
        { "type": "use_block", "name": "read_sot" },
        { "type": "use_block", "name": "get_latest_run" },

        {
          "type": "condition",
          "if": { "left": "run_id", "operator": "==", "right": null },
          "then": { "type": "return", "value": "⚠ BRAK DANYCH" }
        },

        {
          "type": "api",
          "action": "listJobsForWorkflowRun",
          "params": { "run_id": "${run_id}" }
        },

        {
          "type": "transform",
          "mode": "select_failed_job",
          "input": "last_response.jobs",
          "output": "failed_job"
        },

        {
          "type": "condition",
          "if": { "left": "failed_job", "operator": "==", "right": null },
          "then": { "type": "return", "value": "NO FAILED JOB" }
        },

        {
          "type": "extract",
          "path": "failed_job.steps",
          "as": "steps"
        },

        {
          "type": "transform",
          "mode": "classify_error",
          "input": "steps",
          "output": "error_type"
        },

        {
          "type": "interpreter",
          "input": "${error_type}",
          "output": "fix_payload"
        },

        {
          "type": "return",
          "value": "debug_complete"
        }
      ]
    },

    "run_analysis": {
      "intent": ["run analysis", "analizuj"],
      "flow": [
        {
          "type": "api",
          "action": "repositoryDispatch",
          "params": { "event_type": "run_analysis" }
        }
      ]
    }
  }
}
