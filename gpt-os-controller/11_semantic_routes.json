{
  "version": "4.0",
  "routing_rules": {
    "priority_order": [
      "debug_system",
      "check_logs",
      "check_status",
      "read_file",
      "write_file",
      "list_files",
      "run_analysis"
    ],
    "mode_override": {
      "DEBUG": "debug_system"
    }
  },
  "routes": {
    "debug_system": {
      "keywords": [
        "debug",
        "napraw",
        "fix",
        "repair",
        "troubleshoot",
        "resolve issue"
      ],
      "action": "debug_system",
      "priority": 1,
      "requires": [],
      "blocked_in": []
    },
    "check_logs": {
      "keywords": [
        "logs",
        "error",
        "b\u0142\u0105d",
        "co si\u0119 wywali\u0142o",
        "show logs",
        "failure logs"
      ],
      "action": "check_logs",
      "priority": 2,
      "requires": [],
      "blocked_in": []
    },
    "check_status": {
      "keywords": [
        "status",
        "run",
        "pipeline status",
        "czy dzia\u0142a",
        "is it working"
      ],
      "action": "check_status",
      "priority": 3,
      "requires": [],
      "blocked_in": []
    },
    "read_file": {
      "keywords": [
        "read file",
        "czytaj plik",
        "open file",
        "file content"
      ],
      "action": "read_file",
      "priority": 4,
      "requires": [],
      "blocked_in": []
    },
    "write_file": {
      "keywords": [
        "write file",
        "zapisz plik",
        "update file",
        "create file"
      ],
      "action": "write_file",
      "priority": 5,
      "requires": [
        "interpreter"
      ],
      "blocked_in": [
        "DEBUG"
      ]
    },
    "list_files": {
      "keywords": [
        "files",
        "repo tree",
        "list repo",
        "ls"
      ],
      "action": "list_files",
      "priority": 6,
      "requires": [],
      "blocked_in": []
    },
    "run_analysis": {
      "keywords": [
        "analyze",
        "analysis",
        "scan repo",
        "inspect"
      ],
      "action": "run_analysis",
      "priority": 7,
      "requires": [],
      "blocked_in": []
    }
  },
  "governor_integration": true,
  "interpreter_enforced": true,
  "_fallback": {
    "mode": "controller_mode",
    "condition": "no_route_match"
  }
}