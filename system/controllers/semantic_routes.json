{
  "version": "7.2",
  "role": "fallback_classifier_only",

  "routing_rules": {
    "priority_order": [
      "debug_system",
      "read_file",
      "write_file",
      "list_repo"
    ],

    "mode_override": {
      "DEBUG": {
        "action": "debug_system",
        "enforce_execution": true
      }
    },

    "match_required": false,
    "no_fallback": false,

    "chain_aware": true,
    "allow_multi_step_trigger": true
  },

  "routes": {

    "debug_system": {
      "keywords": [
        "debug", "napraw", "fix", "repair",
        "troubleshoot", "resolve issue"
      ],
      "output": {
        "intent_hint": "debug"
      },
      "priority": 1,
      "requires": ["sot_loaded"],
      "enforce_execution": true,
      "execution_type": "chain"
    },

    "read_file": {
      "keywords": [
        "read file", "czytaj plik", "open file", "file content"
      ],
      "output": {
        "intent_hint": "read_file"
      },
      "priority": 2,
      "requires": ["sot_loaded"],
      "enforce_execution": true,
      "execution_type": "single"
    },

    "write_file": {
      "keywords": [
        "write file", "zapisz plik", "update file", "create file"
      ],
      "output": {
        "intent_hint": "write_file"
      },
      "priority": 3,
      "requires": ["sot_loaded", "interpreter_required"],
      "enforce_execution": true,
      "execution_type": "single"
    },

    "list_repo": {
      "keywords": [
        "files", "repo", "repo tree", "list repo", "ls",
        "inspect", "check", "organize",
        "wracamy", "start", "continue"
      ],
      "output": {
        "intent_hint": "list_repo"
      },
      "priority": 4,
      "requires": ["sot_loaded"],
      "enforce_execution": true,
      "execution_type": "single"
    }
  },

  "intent_override": {
    "enabled": false
  },

  "execution_rules": {
    "must_execute": true,
    "validate_execution": true,
    "no_simulation": true,
    "require_api_or_interpreter": true,
    "allow_intent_override": true,

    "execution_modes": {
      "single": true,
      "chain": true
    }
  },

  "governor_integration": {
    "enabled": true,
    "pre_execution": false,
    "post_execution": true,
    "validate_api": true,
    "validate_interpreter": true,
    "validate_chain": true
  },

  "fallback_behavior": {
    "on_no_route": "use_intent_override",
    "on_no_execution": "â  BRAK DANYCH",
    "on_validation_fail": "â  BRAK DANYCH"
  },

  "output": {
    "type": "intent_hint_only",
    "no_execution": true
  }
}
