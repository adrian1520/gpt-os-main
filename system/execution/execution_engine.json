{
  "id": "execution_system",
  "version": "1.1",
  "type": "execution_engine",

  "purpose": "Deterministic execution system aligned with execution-first architecture (chain-enabled)",

  "system_model": {
    "gpt": "generator",
    "interpreter": "validator",
    "api": "execution"
  },

  "global_rule": {
    "rule": "EXECUTION_MUST_BE_ATTEMPTED_BEFORE_VALIDATION"
  },

  "entry_rule": {
    "required_input": "execution_chain",
    "source": "execution_binding_layer",
    "on_violation": "⚠ BRAK DANYCH"
  },

  "forbidden": [
    "direct_api_execution",
    "execution_without_contract",
    "execution_without_binding"
  ],

  "core_flow": {
    "sequence": [
      "SOT",
      "INTENT",
      "EXECUTION",
      "VALIDATION"
    ]
  },

  "execution_modes": {
    "single": {
      "condition": "single_command_detected",
      "flow": [
        "execute_command"
      ]
    },
    "chain": {
      "condition": "execution_chain_present",
      "flow": [
        "iterate_steps",
        "execute_each_step",
        "validate_each_step"
      ]
    }
  },

  "execution_requirement": {
    "condition": "intent_resolved",
    "action": "must_attempt_execution",
    "methods": [
      "api",
      "interpreter_plus_api",
      "execution_chain"
    ],
    "on_fail": "â  BRAK DANYCH"
  },

  "execution_chain": {
    "definition": "ordered list of commands from command_contract",

    "rules": [
      "must_use_command_contract_only",
      "must_preserve_order",
      "must_be_executable_step_by_step",
      "no_empty_chain",
      "no_non_executable_steps"
    ],

    "loop": {
      "type": "for_each",
      "input": "execution_chain",
      "steps": [
        {
          "type": "resolve_command",
          "source": "command_contract"
        },
        {
          "type": "execute",
          "via": [
            "api",
            "interpreter_if_required"
          ]
        },
        {
          "type": "validate_step",
          "checks": [
            "api_called_if_required",
            "interpreter_used_if_write"
          ],
          "on_fail": "â  BRAK DANYCH"
        }
      ]
    }
  },

  "interpreter_rule": {
    "valid_write_flow": [
      {
        "type": "api",
        "action": "getFileContent",
        "params": {
          "sha": "fresh"
        }
      },
      {
        "type": "interpreter",
        "actions": [
          "normalize",
          "validate",
          "encode_base64"
        ]
      },
      {
        "type": "api",
        "action": "createOrUpdateFile"
      }
    ]
  },

  "gpt_rule": {
    "constraints": [
      "generate_raw_only",
      "never_encode_base64",
      "never_construct_api_payload"
    ]
  },

  "sha_safety": {
    "rules": [
      "always_fetch_fresh_sha",
      "retry_once_on_conflict"
    ]
  },

  "read_rule": {
    "conditions": [
      {
        "if": "read_required",
        "then": "must_call_api"
      },
      {
        "if": "api_not_used",
        "then": "â  BRAK DANYCH"
      }
    ]
  },

  "no_simulation_rule": {
    "condition": "execution_expected AND execution_trace_empty",
    "action": "â  BRAK DANYCH"
  },

  "execution_types": {
    "read": "api",
    "write": "interpreter_plus_api",
    "async": "repositoryDispatch_non_write_only",
    "on_misuse": "â  BRAK DANYCH"
  },

  "response_policy": {
    "allowed": [
      "api_result",
      "interpreter_result",
      "execution_based_explanation",
      "â  BRAK DANYCH",
      "â  INTERPRETER REQUIRED"
    ]
  },

  "final_rule": {
    "conditions": [
      "execution_not_attempted",
      "api_not_used_when_required"
    ],
    "action": "â  BRAK DANYCH"
  }
}
