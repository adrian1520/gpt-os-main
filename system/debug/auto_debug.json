{
  "id": "auto_debug",
  "version": "1.0",
  "type": "execution_debug_system",

  "purpose": "Deterministic debug system aligned with execution-first architecture",

  "execution_mode": "via_command_contract",

  "principle": {
    "definition": "Debug = execution-driven, not validation-driven"
  },

  "global_failure_rule": {
    "condition": "sot_not_loaded",
    "action": "⚠ BRAK DANYCH"
  },

  "boot_requirement": {
    "before": "debug",
    "steps": [
      {
        "type": "api",
        "action": "getFileContent",
        "params": {
          "path": "memory/source_of_truth.json"
        }
      },
      {
        "type": "validate",
        "check": "api_called",
        "on_fail": "⚠ BRAK DANYCH"
      },
      {
        "type": "validate",
        "check": "api_success",
        "on_fail": "⚠ BRAK DANYCH"
      },
      {
        "type": "parse",
        "target": "state"
      },
      {
        "type": "detect",
        "target": "mode"
      }
    ]
  },

  "mode_rule": {
    "conditions": [
      {
        "if": "mode == DEBUG",
        "then": "debug_priority"
      },
      {
        "else": "debug_allowed_not_forced"
      }
    ]
  },

  "execution_model": {
    "flow": [
      "STEP",
      "EXECUTION",
      "VALIDATION"
    ],
    "rules": [
      "EXECUTION_MUST_BE_ATTEMPTED_FIRST"
    ]
  },

  "steps": [

    {
      "id": "detect_failure",
      "actions": [
        {
          "type": "api",
          "action": "listWorkflowRuns",
          "params": {
            "per_page": 1
          }
        },
        {
          "type": "extract",
          "fields": ["run_id", "conclusion"]
        }
      ],
      "logic": {
        "if": "conclusion != failure",
        "then": "RETURN_NO_FAILURE_DETECTED"
      }
    },

    {
      "id": "get_execution_data",
      "actions": [
        {
          "type": "api",
          "action": "listJobsForWorkflowRun",
          "params": {
            "run_id": "${run_id}"
          }
        },
        {
          "type": "extract",
          "fields": ["failed_job", "steps"]
        }
      ],
      "conditions": [
        {
          "if": "failed_job_not_found",
          "then": "⚠ BRAK DANYCH"
        }
      ]
    },

    {
      "id": "analyze_error",
      "classification": [
        { "match": "yaml", "type": "YAML_ERROR" },
        { "match": "python", "type": "PYTHON_ERROR" },
        { "match": "No such file", "type": "MISSING_FILE" },
        { "match": "path", "type": "PATH_ERROR" },
        { "match": "syntax", "type": "SYNTAX_ERROR" }
      ],
      "default": "UNKNOWN_ERROR",
      "logic": {
        "if": "UNKNOWN_ERROR",
        "then": "RETURN_UNKNOWN_ERROR"
      }
    },

    {
      "id": "apply_fix",
      "mode": "contract_only",
      "use_command": "write_file",
      "rules": [
        "minimal_patch_only",
        "no_full_rewrite"
      ]
    },

    {
      "id": "memory_write",
      "pipeline": [
        {
          "type": "api",
          "action": "getFileContent"
        },
        {
          "type": "interpreter"
        },
        {
          "type": "api",
          "action": "createOrUpdateFile"
        }
      ],
      "targets": [
        "memory/debug/run_<id>.json",
        "memory/source_of_truth.json"
      ]
    },

    {
      "id": "redeploy",
      "actions": [
        {
          "type": "api",
          "action": "rerunWorkflowRun",
          "params": {
            "run_id": "${run_id}"
          }
        }
      ]
    },

    {
      "id": "verify",
      "actions": [
        {
          "type": "api",
          "action": "listWorkflowRuns",
          "params": {
            "per_page": 1
          }
        }
      ],
      "result_logic": [
        {
          "if": "conclusion == success",
          "then": "SUCCESS"
        },
        {
          "else": "FAILURE"
        }
      ]
    }
  ],

  "no_simulation_rule": {
    "condition": "execution_not_attempted",
    "action": "⚠ BRAK DANYCH"
  },

  "response_policy": {
    "allowed": [
      "SUCCESS",
      "FAILURE",
      "UNKNOWN_ERROR",
      "NO FAILURE DETECTED",
      "⚠ BRAK DANYCH",
      "⚠ INTERPRETER REQUIRED"
    ]
  },

  "final_rule": {
    "condition": [
      "sot_not_loaded",
      "execution_not_attempted"
    ],
    "action": "⚠ BRAK DANYCH"
  }
}
