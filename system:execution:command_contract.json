{
  "contract_type": "execution_only",
  "version": "8.0",

  "config": {
    "strict_mode": true,
    "auto_debug": true,
    "max_steps": 20,
    "interpreter_required_for_write": true,
    "enforce_execution": true,
    "default_error": "⚠ BRAK DANYCH"
  },

  "blocks": {

    "read_sot": [
      {
        "type": "api",
        "action": "getFileContent",
        "params": {
          "owner": "adrian1520",
          "repo": "gpt-os-main",
          "path": "memory/source_of_truth.json"
        }
      },
      { "type": "validate", "check": "api_called" },

      { "type": "extract", "path": "content", "as": "sot_raw" },

      {
        "type": "condition",
        "if": { "left": "sot_raw", "operator": "==", "right": null },
        "then": { "type": "return", "value": "⚠ BRAK DANYCH" }
      },

      {
        "type": "parse_json",
        "input": "sot_raw",
        "as": "sot"
      }
    ],

    "execution_chain_runner": [
      {
        "type": "loop",
        "input": "execution_chain",
        "max_steps": "${config.max_steps}",
        "steps": [
          {
            "type": "resolve_command",
            "from": "commands",
            "field": "command",
            "as": "resolved_command"
          },
          {
            "type": "inject_params",
            "source": "step.params"
          },
          {
            "type": "execute_flow",
            "target": "resolved_command.flow"
          },
          {
            "type": "validate",
            "check": "execution_success"
          }
        ],
        "on_fail": "⚠ BRAK DANYCH"
      }
    ]

  },

  "commands": {

    "execute_fallback_api": {
      "flow": [
        { "type": "use_block", "name": "read_sot" },

        {
          "type": "validate",
          "check": "operation_allowed"
        },

        {
          "type": "api",
          "action": "${operationId}",
          "params": "${params}"
        },

        { "type": "validate", "check": "api_called" }
      ]
    },

    "read_memory": {
      "flow": [
        { "type": "use_block", "name": "read_sot" },

        {
          "type": "api",
          "action": "getFileContent",
          "params": {
            "owner": "adrian1520",
            "repo": "gpt-os-main",
            "path": "${memory_path}"
          }
        },

        { "type": "validate", "check": "api_called" }
      ]
    },

    "write_memory": {
      "flow": [
        { "type": "use_block", "name": "read_sot" },

        {
          "type": "interpreter",
          "mode": "prepare_content",
          "input": "${memory_content}",
          "output": "encoded"
        },

        { "type": "validate", "check": "interpreter_used" },

        {
          "type": "api",
          "action": "createOrUpdateFile",
          "params": {
            "owner": "adrian1520",
            "repo": "gpt-os-main",
            "path": "${memory_path}",
            "content": "${encoded}",
            "message": "memory update"
          }
        },

        { "type": "validate", "check": "api_called" }
      ]
    },

    "default_repo_check": {
      "flow": [
        { "type": "use_block", "name": "read_sot" },
        {
          "type": "api",
          "action": "listRepositoryContents",
          "params": {
            "owner": "adrian1520",
            "repo": "gpt-os-main"
          }
        },
        { "type": "validate", "check": "api_called" }
      ]
    },

    "read_file": {
      "flow": [
        { "type": "use_block", "name": "read_sot" },
        {
          "type": "api",
          "action": "getFileContent",
          "params": {
            "owner": "adrian1520",
            "repo": "gpt-os-main",
            "path": "${path}"
          }
        },
        { "type": "validate", "check": "api_called" }
      ]
    },

    "write_file": {
      "flow": [
        { "type": "use_block", "name": "read_sot" },

        {
          "type": "api",
          "action": "getFileContent",
          "params": {
            "owner": "adrian1520",
            "repo": "gpt-os-main",
            "path": "${path}"
          }
        },

        { "type": "validate", "check": "api_called_optional" },

        { "type": "extract", "path": "sha", "as": "sha" },

        {
          "type": "condition",
          "if": { "left": "sha", "operator": "==", "right": null },
          "then": { "type": "set", "field": "sha", "value": null }
        },

        {
          "type": "interpreter",
          "mode": "prepare_content",
          "input": "${content}",
          "output": "encoded_content"
        },

        { "type": "validate", "check": "interpreter_used" },

        {
          "type": "api",
          "action": "createOrUpdateFile",
          "params": {
            "owner": "adrian1520",
            "repo": "gpt-os-main",
            "path": "${path}",
            "content": "${encoded_content}",
            "message": "${message}",
            "sha": "${sha}"
          }
        },

        { "type": "validate", "check": "api_called" }
      ]
    },

    "list_repo": {
      "flow": [
        { "type": "use_block", "name": "read_sot" },
        {
          "type": "api",
          "action": "listRepositoryContents",
          "params": {
            "owner": "adrian1520",
            "repo": "gpt-os-main"
          }
        },
        { "type": "validate", "check": "api_called" }
      ]
    },

    "analyze_repo": {
      "flow": [
        { "type": "use_block", "name": "read_sot" },
        {
          "type": "api",
          "action": "listRepositoryContents",
          "params": {
            "owner": "adrian1520",
            "repo": "gpt-os-main"
          }
        },
        { "type": "validate", "check": "api_called" }
      ]
    },

    "debug_system": {
      "flow": [
        { "type": "use_block", "name": "read_sot" },

        {
          "type": "api",
          "action": "listWorkflowRuns",
          "params": {
            "owner": "adrian1520",
            "repo": "gpt-os-main",
            "per_page": 1
          }
        },

        { "type": "validate", "check": "api_called" },

        {
          "type": "extract",
          "path": "workflow_runs[0].id",
          "as": "run_id"
        },

        {
          "type": "extract",
          "path": "workflow_runs[0].conclusion",
          "as": "conclusion"
        },

        {
          "type": "condition",
          "if": {
            "left": "conclusion",
            "operator": "!=",
            "right": "failure"
          },
          "then": {
            "type": "return",
            "value": "NO FAILURE DETECTED"
          }
        },

        {
          "type": "api",
          "action": "listJobsForWorkflowRun",
          "params": {
            "owner": "adrian1520",
            "repo": "gpt-os-main",
            "run_id": "${run_id}"
          }
        },

        { "type": "validate", "check": "api_called" }
      ]
    }

  },

  "validation": {
    "required_fields": ["command", "flow"],
    "forbidden": ["intent"]
  }
}